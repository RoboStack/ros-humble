diff --git a/lbr_fri_ros2/CMakeLists.txt b/lbr_fri_ros2/CMakeLists.txt
index a26f445..96a1721 100644
--- a/lbr_fri_ros2/CMakeLists.txt
+++ b/lbr_fri_ros2/CMakeLists.txt
@@ -13,7 +13,35 @@ endif()
 find_package(ament_cmake REQUIRED)
 find_package(eigen3_cmake_module REQUIRED)
 find_package(Eigen3)
-find_package(FRIClient REQUIRED)
+if(WIN32)
+  # Windows fallback for SDK packages with inconsistent CMake exports / layouts.
+  add_compile_definitions(NOMINMAX _USE_MATH_DEFINES)
+  file(WRITE "${CMAKE_CURRENT_BINARY_DIR}/windows_macro_fix.h" "#pragma once\n")
+  file(APPEND "${CMAKE_CURRENT_BINARY_DIR}/windows_macro_fix.h" "#ifndef WIN32_LEAN_AND_MEAN\n#define WIN32_LEAN_AND_MEAN\n#endif\n")
+  file(APPEND "${CMAKE_CURRENT_BINARY_DIR}/windows_macro_fix.h" "#ifndef NOMINMAX\n#define NOMINMAX\n#endif\n")
+  file(APPEND "${CMAKE_CURRENT_BINARY_DIR}/windows_macro_fix.h" "#include <winsock2.h>\n")
+  file(APPEND "${CMAKE_CURRENT_BINARY_DIR}/windows_macro_fix.h" "#include <windows.h>\n")
+  file(APPEND "${CMAKE_CURRENT_BINARY_DIR}/windows_macro_fix.h" "#ifdef ERROR\n#undef ERROR\n#endif\n")
+  include_directories(BEFORE "${CMAKE_CURRENT_BINARY_DIR}")
+  add_compile_options($<$<CXX_COMPILER_ID:MSVC>:/FI${CMAKE_CURRENT_BINARY_DIR}/windows_macro_fix.h>)
+
+  find_path(FRICLIENT_INCLUDE_DIR
+    NAMES friLBRClient.h friClientApplication.h friClientSdk/friLBRClient.h friClientSdk/friClientApplication.h
+    PATH_SUFFIXES include Library/include)
+  find_library(FRICLIENT_LIBRARY
+    NAMES FRIClient libFRIClient
+    PATH_SUFFIXES lib Library/lib)
+
+  if(NOT FRICLIENT_INCLUDE_DIR OR NOT FRICLIENT_LIBRARY)
+    message(FATAL_ERROR "Could not locate FRIClient headers/library on Windows")
+  endif()
+
+  if(NOT TARGET FRIClient::FRIClient)
+    add_library(FRIClient::FRIClient UNKNOWN IMPORTED)
+    set_target_properties(FRIClient::FRIClient PROPERTIES
+      IMPORTED_LOCATION "${FRICLIENT_LIBRARY}"
+      INTERFACE_INCLUDE_DIRECTORIES "${FRICLIENT_INCLUDE_DIR}")
+  endif()
+else()
+  find_package(FRIClient REQUIRED)
+endif()
 find_package(geometry_msgs REQUIRED)
 find_package(kdl_parser REQUIRED)
 find_package(lbr_fri_idl REQUIRED)
